generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  COURIER
}

enum RideStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ScoreConfidenceLevel {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  passwordHash String
  role         UserRole @default(COURIER)
  isActive     Boolean  @default(true)
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rides   Ride[]
  devices Device[]
}

model Ride {
  id             String     @id @default(cuid())
  userId         String
  startedAt      DateTime
  endedAt        DateTime?
  status         RideStatus @default(ACTIVE)
  totalDistanceM Float?     @default(0)
  durationS      Int?       @default(0)
  score          Float?
  scoreVersion   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  telemetryPoints TelemetryPoint[]
  rideEvents      RideEvent[]
  analytics       RideAnalytics?
  scoreCard       RideScore?

  @@index([userId, status])
  @@index([startedAt])
}

model TelemetryPoint {
  id           String   @id @default(cuid())
  rideId       String
  userId       String
  ts           DateTime
  lat          Float
  lng          Float
  speedKmh     Float?
  accuracyM    Float?
  heading      Float?
  accelX       Float?
  accelY       Float?
  accelZ       Float?
  batteryLevel Float?
  networkType  String?
  createdAt    DateTime @default(now())

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@index([rideId, ts])
  @@index([userId, ts])
}

model RideEvent {
  id        String   @id @default(cuid())
  rideId    String
  userId    String
  type      String
  ts        DateTime
  lat       Float?
  lng       Float?
  severity  Float?
  metaJson  Json?
  createdAt DateTime @default(now())

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@index([rideId, type, ts])
  @@index([userId, ts])
}

model RideAnalytics {
  id               String   @id @default(cuid())
  rideId           String   @unique
  sampleCount      Int      @default(0)
  validPointCount  Int      @default(0)
  gpsGapCount      Int      @default(0)
  lowAccuracyCount Int      @default(0)
  movingSeconds    Int      @default(0)
  idleSeconds      Int      @default(0)
  totalDistanceM   Float    @default(0)
  avgSpeedKmh      Float?
  p95SpeedKmh      Float?
  maxSpeedKmh      Float?
  medianAccuracyM  Float?
  qualityScore     Float?
  qualityFlags     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
}

model RideScore {
  id              String               @id @default(cuid())
  rideId          String               @unique
  totalScore      Float
  safetyScore     Float?
  complianceScore Float?
  smoothnessScore Float?
  efficiencyScore Float?
  confidenceLevel ScoreConfidenceLevel @default(MEDIUM)
  scoringVersion  String
  breakdownJson   Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
}

model Device {
  id          String   @id @default(cuid())
  userId      String
  deviceModel String?
  osVersion   String?
  appVersion  String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}