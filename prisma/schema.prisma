generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COURIER
}

enum RideStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id           String    @id @default(cuid())
  name         String
  phone        String    @unique
  passwordHash String
  role         UserRole  @default(COURIER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  rides        Ride[]
  devices      Device[]
}

model Ride {
  id              String      @id @default(cuid())
  userId          String
  startedAt       DateTime
  endedAt         DateTime?
  status          RideStatus  @default(ACTIVE)
  totalDistanceM  Float?      @default(0)
  durationS       Int?        @default(0)
  score           Float?
  scoreVersion    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id])
  telemetryPoints TelemetryPoint[]
  rideEvents      RideEvent[]
}

model TelemetryPoint {
  id           String   @id @default(cuid())
  rideId       String
  userId       String
  ts           DateTime
  lat          Float
  lng          Float
  speedKmh     Float?
  accuracyM    Float?
  heading      Float?
  accelX       Float?
  accelY       Float?
  accelZ       Float?
  batteryLevel Float?
  networkType  String?
  createdAt    DateTime @default(now())

  ride         Ride     @relation(fields: [rideId], references: [id])
}

model RideEvent {
  id         String   @id @default(cuid())
  rideId     String
  userId     String
  type       String
  ts         DateTime
  lat        Float?
  lng        Float?
  severity   Float?
  metaJson   Json?
  createdAt  DateTime @default(now())

  ride       Ride     @relation(fields: [rideId], references: [id])
}

model Device {
  id          String   @id @default(cuid())
  userId      String
  deviceModel String?
  osVersion   String?
  appVersion  String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}